# Copy this file to .env and fill in your real values.
# Never commit .env to git (it is in .gitignore).
# Quotes are optional (e.g. my_key or "my_key" both work).

# Firebase Web App config (from Firebase Console > Project settings > Your apps)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890123
VITE_FIREBASE_APP_ID=1:1234567890123:web:abcdef123456
